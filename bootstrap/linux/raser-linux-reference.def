Bootstrap: docker
From: ghcr.io/astral-sh/uv:python3.11-bookworm-slim

%files
    env/uv.txt /opt/raser/uv.txt

%environment
    export LC_ALL=C
    export LANG=C

    export VIRTUAL_ENV=/opt/raser-venv
    export UV_CACHE_DIR=/opt/raser/uv-cache
    export PATH=/opt/raser/bin:$VIRTUAL_ENV/bin:$PATH
    export PYTHONHOME=
    export PYTHONPATH=
    export PYTHONNOUSERSITE=1
    export MPLBACKEND=${MPLBACKEND:-Agg}
    export MPLCONFIGDIR=${MPLCONFIGDIR:-/tmp/raser-matplotlib}
    if [ -n "${GEANT4_INSTALL:-}" ] && [ -d "$GEANT4_INSTALL/bin" ]; then
        export PATH=$GEANT4_INSTALL/bin:$PATH
    fi

%post
    set -ex
    export DEBIAN_FRONTEND=noninteractive
    export MPLCONFIGDIR=/tmp/raser-matplotlib
    mkdir -p $MPLCONFIGDIR

    apt_mirror=http://repo.huaweicloud.com
    for apt_source in /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do
        [ -f "$apt_source" ] || continue
        sed -i \
            -e "s@http://deb.debian.org/debian-security@$apt_mirror/debian-security@g" \
            -e "s@http://security.debian.org/debian-security@$apt_mirror/debian-security@g" \
            -e "s@http://deb.debian.org/debian@$apt_mirror/debian@g" \
            "$apt_source"
    done
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 update
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 install -y --no-install-recommends \
        ca-certificates \
        git \
        bash \
        g++ \
        ngspice
    rm -rf /var/lib/apt/lists/*

    export VIRTUAL_ENV=/opt/raser-venv
    export UV_CACHE_DIR=/opt/raser/uv-cache
    export PATH=$VIRTUAL_ENV/bin:$PATH
    export CC=/usr/bin/gcc
    export CXX=/usr/bin/g++
    export CPPFLAGS=
    export CFLAGS=
    export CXXFLAGS=
    export LDFLAGS=

    uv venv --python /usr/local/bin/python3.11 $VIRTUAL_ENV
    uv pip sync --python $VIRTUAL_ENV/bin/python /opt/raser/uv.txt
    mkdir -p /opt/raser/bin
    cat > /opt/raser/bin/python <<'EOF'
#!/bin/sh
unset PYTHONHOME
[ -n "${PYTHONPATH:-}" ] || unset PYTHONPATH
export PYTHONNOUSERSITE=1
exec /opt/raser-venv/bin/python "$@"
EOF
    chmod +x /opt/raser/bin/python
    ln -sf /opt/raser/bin/python /opt/raser/bin/python3
    cat > /opt/raser/bin/geant4-config <<'EOF'
#!/bin/sh
for prefix in "$GEANT4_INSTALL" "$GEANT4_DIR"; do
    if [ -n "$prefix" ] && [ -x "$prefix/bin/geant4-config" ]; then
        exec "$prefix/bin/geant4-config" "$@"
    fi
done
echo "geant4-config: set GEANT4_INSTALL or GEANT4_DIR to a Geant4 installation" >&2
exit 127
EOF
    chmod +x /opt/raser/bin/geant4-config
    ln -sf /opt/raser/bin/geant4-config /usr/local/bin/geant4-config
    rm -rf $UV_CACHE_DIR

    $VIRTUAL_ENV/bin/python -c "import importlib.util; assert importlib.util.find_spec('g4ppyy')"
    ngspice -v

%runscript
    exec /bin/bash "$@"
