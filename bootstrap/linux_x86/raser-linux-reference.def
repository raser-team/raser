Bootstrap: docker
From: ghcr.io/astral-sh/uv:python3.11-bookworm-slim

%files
    env/uv-linux-x86.txt /opt/raser/uv-linux-x86.txt

%environment
    export LC_ALL=C
    export LANG=C

    export VIRTUAL_ENV=/opt/raser-venv
    export UV_CACHE_DIR=/opt/raser/uv-cache
    export PATH=/opt/raser/bin:$VIRTUAL_ENV/bin:$PATH
    export PYTHONHOME=
    export PYTHONPATH=
    export PYTHONNOUSERSITE=1
    export MPLBACKEND=${MPLBACKEND:-Agg}
    export MPLCONFIGDIR=${MPLCONFIGDIR:-/tmp/raser-matplotlib}
    if [ -n "${GEANT4_INSTALL:-}" ] && [ -d "$GEANT4_INSTALL/bin" ]; then
        export PATH=$GEANT4_INSTALL/bin:$PATH
    fi

%post
    set -ex
    export DEBIAN_FRONTEND=noninteractive
    export MPLCONFIGDIR=/tmp/raser-matplotlib
    mkdir -p $MPLCONFIGDIR

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        bash \
        g++ \
        ngspice
    rm -rf /var/lib/apt/lists/*

    export VIRTUAL_ENV=/opt/raser-venv
    export UV_CACHE_DIR=/opt/raser/uv-cache
    export PATH=$VIRTUAL_ENV/bin:$PATH
    export CC=/usr/bin/gcc
    export CXX=/usr/bin/g++
    export CPPFLAGS=
    export CFLAGS=
    export CXXFLAGS=
    export LDFLAGS=

    uv venv --python /usr/local/bin/python3.11 $VIRTUAL_ENV
    uv pip sync --python $VIRTUAL_ENV/bin/python /opt/raser/uv-linux-x86.txt
    mkdir -p /opt/raser/bin
    cat > /opt/raser/bin/python <<'EOF'
#!/bin/sh
unset PYTHONHOME
[ -n "${PYTHONPATH:-}" ] || unset PYTHONPATH
export PYTHONNOUSERSITE=1
exec /opt/raser-venv/bin/python "$@"
EOF
    chmod +x /opt/raser/bin/python
    ln -sf /opt/raser/bin/python /opt/raser/bin/python3
    cat > /opt/raser/bin/geant4-config <<'EOF'
#!/bin/sh
for prefix in "$GEANT4_INSTALL" "$GEANT4_DIR"; do
    if [ -n "$prefix" ] && [ -x "$prefix/bin/geant4-config" ]; then
        exec "$prefix/bin/geant4-config" "$@"
    fi
done
echo "geant4-config: set GEANT4_INSTALL or GEANT4_DIR to a Geant4 installation" >&2
exit 127
EOF
    chmod +x /opt/raser/bin/geant4-config
    $VIRTUAL_ENV/bin/python - <<'PY'
from pathlib import Path
import importlib.util

root = Path(importlib.util.find_spec("g4ppyy").origin).parent

loader = root / "_lazy_loader.py"
text = loader.read_text()
old = '''    vals = lib_output.split()
    lib_dir = vals[0].replace("-L","")

    libraries = []
    for x in vals[1:]:
        libraries.append( x.replace("-l","") )
'''
new = '''    vals = lib_output.split()

    libraries = []
    for x in vals:
        if x.startswith("-L"):
            lib_dir = x[2:]
            if _os.path.isdir(lib_dir):
                cppyy.add_library_path(lib_dir)
        elif x.startswith("-l"):
            libraries.append(x[2:])
'''
if old not in text:
    raise RuntimeError("g4ppyy library parser patch did not match")
loader.write_text(text.replace(old, new))

init = root / "__init__.py"
text = init.read_text()
text = text.replace("import sys as _sys\n", "import sys as _sys\nimport os as _os\n")
text = text.replace("from . import vis\n", "if _os.environ.get(\"G4PPYY_LOAD_VIS\") == \"1\":\n    from . import vis\n")
text = text.replace("from . import magic as _magic\n", "if _os.environ.get(\"G4PPYY_LOAD_MAGIC\") == \"1\":\n    from . import magic as _magic\n")
init.write_text(text)

run = root / "run.py"
text = run.read_text()

def replace_once(blob, old, new, label):
    if old not in blob:
        raise RuntimeError(f"g4ppyy {label} patch did not match")
    return blob.replace(old, new)

text = replace_once(text, "from . import vis as _vis\n", "_vis = None\n", "run vis import")
text = replace_once(
text,
'''def create_mpl_visualization(gRunManager):
    global visManager
    if not visManager:
        visManager = _vis.build("MPL", "quiet")
        print("Running initializer")
''',
'''def create_mpl_visualization(gRunManager):
    global _vis
    if _vis is None:
        from . import vis as _vis
    global visManager
    if not visManager:
        visManager = _vis.build("MPL", "quiet")
        print("Running initializer")
''',
"run mpl visualization",
)
text = replace_once(
text,
'''def create_visualization(gRunManager, option="K3D"):
    global visManager
    if not visManager:
        visManager = _vis.register_graphics_systems()
        print("Running initializer")
''',
'''def create_visualization(gRunManager, option="K3D"):
    global _vis
    if _vis is None:
        from . import vis as _vis
    global visManager
    if not visManager:
        visManager = _vis.register_graphics_systems()
        print("Running initializer")
''',
"run k3d visualization",
)
run.write_text(text)

managers = root / "managers.py"
text = managers.read_text()
text = replace_once(
text,
'''# Visualisation Tools
from . import vis as _vis

global VisExecutive
VisExecutive = _vis.register_graphics_systems()
_g4.assign("gVisExecutive", VisExecutive)
''',
'''# Visualisation Tools
global VisExecutive
VisExecutive = None
if _os.environ.get("G4PPYY_LOAD_VIS") == "1":
    from . import vis as _vis
    VisExecutive = _vis.register_graphics_systems()
    _g4.assign("gVisExecutive", VisExecutive)
''',
"managers visualization",
)
text = replace_once(text, "from . import _lazy_loader as _g4\n", "from . import _lazy_loader as _g4\nimport os as _os\n", "managers os import")
managers.write_text(text)
PY
    rm -rf $UV_CACHE_DIR

    $VIRTUAL_ENV/bin/python -c "import cppyy, importlib.util; assert importlib.util.find_spec('g4ppyy')"
    ngspice -v

%runscript
    exec /bin/bash "$@"
